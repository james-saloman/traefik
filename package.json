{
  "name": "traefik-mastery",
  "version": "1.0.0",
  "description": "A comprehensive learning resource for mastering Traefik reverse proxy and networking fundamentals",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "node scripts/dev-server.js",
    "start:docs": "docusaurus start",
    "build": "docusaurus build && node scripts/merge-static.js",
    "build:gh-pages": "DEPLOY_TARGET=gh-pages docusaurus build && DEPLOY_TARGET=gh-pages node scripts/merge-static.js",
